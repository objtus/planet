[database]
host     = "localhost"
port     = 5432
name     = "planet"
user     = "planet"
password = "password"

[misskey.misskey_io]
base_url = "https://misskey.io"
token    = "YOUR_MISSKEY_IO_TOKEN"

[misskey.tanoshii_site]
base_url = "https://tanoshii.site"
token    = "YOUR_TANOSHII_SITE_TOKEN"

[mastodon.mistodon_cloud]
base_url      = "https://mistodon.cloud"
access_token  = "YOUR_MASTODON_ACCESS_TOKEN"

[lastfm]
api_key    = "YOUR_LASTFM_API_KEY"
username   = "objtus"

[openweathermap]
api_key  = "YOUR_OPENWEATHERMAP_API_KEY"
lat      = 35.6762
lon      = 139.6503
location = "Tokyo"

[github]
username = "YOUR_GITHUB_USERNAME"
token    = "YOUR_GITHUB_PAT"

[youtube]
api_key    = "YOUR_YOUTUBE_API_KEY"
channel_id = "YOUR_CHANNEL_ID"

[rss]
url = "https://yuinoid.neocities.org/rss.xml"

[scrapbox]
project       = "stall"
my_icons      = ["health.icon"]
lookback_days = 30

[neocities]
api_key = "YOUR_NEOCITIES_API_KEY"

# planet-feed（Cloudflare Pages 用 JSON を git push）
# repo_path 未指定時は ~/planet-feed
# push = false のときは commit のみ（または --push で上書き）
[planet_feed]
# repo_path は必ずこのマシン上の実パス（例の /home/you/... のままにしない）
# repo_path = "/home/objtus/planet-feed"
# push = true
#
# タイムライン連続折りたたみ（必ずこの [planet_feed] 直下。source_display 内に書かないこと）
# timeline_collapse_types = ["lastfm"]
# timeline_collapse_min_run = 3
#
# Neocities 用 sources[] 上書き（キーは DB の source id）
#
# [planet_feed.source_display.7]
# icon_emoji = "🌤️"
#
# [planet_feed.source_display.4]
# icon_file = "lastfm.svg"
#
# [planet_feed.source_display.8]
# icon_url = "https://github.githubassets.com/favicons/favicon.svg"

# Ollama: 使うモデルは事前に `ollama pull <model>` が必要。利用可能は `ollama list`。
[ollama]
base_url = "http://localhost:11434"
# design.md の例。無い場合は llama3.2 / gemma2:9b 等に変更
model    = "gemma3:12b"

[flask]
secret_key = "change-this-to-a-random-string"
host       = "0.0.0.0"
port       = 5000
debug      = false

# ソース管理の CSV 取り込み（Netflix 詳細）でプロファイル未指定のときの既定
[streaming_import]
netflix_profile = "ホ"

